/* background colors darkest to lightest */
@define-color bg0 {{bg0}};
@define-color bg1 {{bg1}};
@define-color bg2 {{bg2}};
@define-color bg3 {{bg3}};
@define-color bg4 {{bg4}};
/* foreground colors lightest to darkest */
@define-color fg0 {{fg0}};
@define-color fg1 {{fg1}};
@define-color fg2 {{fg2}};
@define-color fg3 {{fg3}};
@define-color fg4 {{fg4}};
/* Primary colors */
@define-color primary        {{primary}};
@define-color darkPrimary    {{darkPrimary}};
@define-color lightPrimary   {{lightPrimary}};
/* Secondary colors */
@define-color secondary      {{secondary}};
@define-color darkSecondary  {{darkSecondary}};
@define-color lightSecondary {{lightSecondary}};
/* Tertiary colors */
@define-color tertiary       {{tertiary}};
@define-color darkTertiary   {{darkTertiary}};
@define-color lightTertiary  {{lightTertiary}};
/* Accent colors */
@define-color red            {{red}};
@define-color orange         {{orange}};
@define-color yellow         {{yellow}};
@define-color green          {{green}};
@define-color aqua           {{aqua}};
@define-color blue           {{blue}};
@define-color purple         {{purple}};

@define-color darkRed        {{darkRed}};
@define-color darkOrange     {{darkOrange}};
@define-color darkYellow     {{darkYellow}};
@define-color darkGreen      {{darkGreen}};
@define-color darkAqua       {{darkAqua}};
@define-color darkBlue       {{darkBlue}};
@define-color darkPurple     {{darkPurple}};

@define-color lightRed       {{lightRed}};
@define-color lightOrange    {{lightOrange}};
@define-color lightYellow    {{lightYellow}};
@define-color lightGreen     {{lightGreen}};
@define-color lightAqua      {{lightAqua}};
@define-color lightBlue      {{lightBlue}};
@define-color lightPurple    {{lightPurple}};
